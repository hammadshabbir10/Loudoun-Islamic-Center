---
/**
 * Blog index — a responsive grid of post cards, newest first.
 * Drafts are hidden in production builds.
 */
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";

const posts = (
  await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title="Blog" description="Articles, guides, and updates.">
  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <header class="mb-12">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Blog</h1>
      <p class="text-muted-foreground mt-2 text-lg">
        Articles, guides, and updates.
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="text-muted-foreground rounded-xl border border-dashed p-12 text-center">
          No posts yet — check back soon.
        </p>
      ) : (
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="focus-visible:ring-ring block h-full rounded-xl focus-visible:ring-2 focus-visible:outline-none"
              >
                <Card className="h-full transition-shadow hover:shadow-md">
                  <CardHeader>
                    <p class="text-muted-foreground text-sm">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {dateFmt.format(post.data.pubDate)}
                      </time>
                    </p>
                    <CardTitle className="text-lg">{post.data.title}</CardTitle>
                    <CardDescription>{post.data.description}</CardDescription>
                  </CardHeader>
                  {post.data.tags.length > 0 && (
                    <CardContent className="flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <Badge variant="secondary">#{tag}</Badge>
                      ))}
                    </CardContent>
                  )}
                </Card>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
