<!-- ════════════════════════════════════════════
     HERO (OPTION 3 — VIDEO BACKGROUND) ← ACTIVE
     Video file: /public/din.mp4
     To switch back to Option 2: wrap this in {/* */} and remove {/* */} from Option 2 above.
════════════════════════════════════════════ -->
<section class="relative flex min-h-dvh flex-col items-center justify-center overflow-hidden text-white" style="min-height: 100svh;">

  <!-- ── Video background ── -->
  <div class="absolute inset-0 z-0 bg-[#0A2B1D]">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      class="h-full w-full object-cover"
      style="filter: brightness(0.55);"
      aria-hidden="true"
    >
      <source src="/loudoun-islamic-center-hero-bg.mp4" type="video/mp4" />
      <!-- Fallback image if video can't load -->
      <img src="/mosque-hero.png" alt="Loudoun Islamic Center" class="h-full w-full object-cover"/>
    </video>
    <!-- Dark gradient overlay from bottom for text readability -->
    <div class="pointer-events-none absolute inset-0" style="background: linear-gradient(to top, rgba(10,43,29,0.90) 0%, rgba(10,43,29,0.35) 55%, rgba(10,43,29,0.10) 100%);"></div>
  </div>

  <!-- ── Overlay text content ── -->
  <div class="relative z-10 mx-auto w-full max-w-[900px] px-6 text-center md:px-16">

    <!-- Logo above the text -->
    <div class="hero-fade mb-8 flex justify-center">
      <div class="inline-block rounded-3xl bg-white/95 p-5 shadow-[0_0_40px_rgba(255,255,255,0.3)] backdrop-blur-md transition-transform hover:scale-105">
        <img
          src="/logo_header.png"
          alt="Loudoun Islamic Center"
          class="h-28 w-auto object-contain md:h-36"
        />
      </div>
    </div>

    <!-- Arabic-style greeting -->
    <p class="hero-fade mb-3 font-display text-2xl italic text-amber-400 drop-shadow-lg md:text-3xl" style="text-shadow: 0 2px 16px rgba(0,0,0,0.6);">
      Assalamu Alaikum
    </p>

    <!-- Main heading -->
    <h1 class="hero-fade hero-fade-1 font-display mb-6 text-4xl font-bold leading-tight tracking-tight text-white md:text-5xl lg:text-6xl" style="text-shadow: 0 4px 24px rgba(0,0,0,0.5);">
      Welcome to<br/>Loudoun Islamic Center
    </h1>

    <!-- Subtext from real website -->
    <p class="hero-fade hero-fade-2 mx-auto mb-10 max-w-2xl text-base leading-relaxed text-white/85 md:text-lg" style="text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
      Please register and become a member of our community.<br class="hidden md:block"/>
      Once registered, you will receive notifications and updates<br class="hidden md:block"/>
      on events being held at the center.
    </p>

    <!-- CTA buttons -->
    <div class="hero-fade hero-fade-3 flex flex-wrap items-center justify-center gap-4">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-full bg-gold px-8 py-3.5 text-sm font-bold text-white shadow-lg shadow-black/30 transition-all hover:scale-105 hover:bg-amber-600"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Join Our Community
      </a>
      <a
        href="/donate"
        class="inline-flex items-center gap-2 rounded-full border-2 border-white/50 px-8 py-3.5 text-sm font-bold text-white backdrop-blur-sm transition-all hover:border-white hover:bg-white/10"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        Donate Now
      </a>
    </div>
  </div>

  <!-- Scroll cue -->
  <a href="#prayer-times" aria-label="Scroll to prayer times" class="absolute bottom-10 left-1/2 z-10 -translate-x-1/2 text-white/60 transition-colors hover:text-white">
    <svg class="h-6 w-6 motion-safe:animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
  </a>
</section>


<!-- ════════════════════════════════════════════
     PRAYER TIMES — full section, big live clock & countdown
════════════════════════════════════════════ -->
<section id="prayer-times" class="relative z-20 mx-auto my-14 max-w-[1400px] scroll-mt-28 px-4 md:my-20 md:px-8">
  <div class="reveal overflow-hidden rounded-3xl border border-outline-variant bg-white shadow-2xl">

    <!-- Dark header: title + BIG clock + BIG countdown -->
    <div class="relative overflow-hidden border-b-4 border-gold bg-primary px-6 py-8 md:px-10 md:py-10">
      <!-- Ambient glows -->
      <div class="pointer-events-none absolute -top-24 -right-24 h-72 w-72 rounded-full bg-gold/15 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-32 -left-16 h-80 w-80 rounded-full bg-emerald-400/10 blur-3xl"></div>
      <div class="pointer-events-none absolute left-1/2 top-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full border border-white/5"></div>

      <div class="relative z-10 grid items-center gap-8 text-center lg:grid-cols-3 lg:text-left">

        <!-- Title + date + PDF -->
        <div>
          <div class="flex items-center justify-center gap-2.5 lg:justify-start">
            <svg class="h-6 w-6 shrink-0 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h2 class="font-display text-2xl font-bold text-white md:text-3xl">Daily Prayer Times</h2>
          </div>
          <p id="et-date" class="mt-2 text-base font-medium text-white/80 md:text-lg"></p>
          <a href="#" class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/25 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Download PDF
          </a>
        </div>

        <!-- BIG live clock -->
        <div class="text-center">
          <p class="text-xs font-bold uppercase tracking-[0.3em] text-gold">Current Time — Eastern</p>
          <p class="mt-2 flex items-baseline justify-center gap-2 whitespace-nowrap">
            <span id="et-clock" class="font-mono text-5xl font-bold tracking-tight text-white tabular-nums [text-shadow:0_0_40px_rgba(251,191,36,0.3)] md:text-6xl xl:text-7xl">--:--:--</span>
            <span id="et-ampm" class="font-mono text-2xl font-bold text-gold md:text-3xl">--</span>
          </p>
        </div>

        <!-- BIG countdown -->
        <div class="flex justify-center lg:justify-end">
          <div class="card-shine w-full max-w-sm rounded-2xl bg-linear-to-br from-gold to-secondary px-8 py-6 text-center shadow-lg shadow-black/20">
            <p class="flex items-center justify-center gap-2 text-xs font-bold uppercase tracking-[0.25em] text-white/90">
              <span class="h-2 w-2 animate-pulse rounded-full bg-white"></span>
              Next Prayer: <span id="next-prayer-name">—</span>
            </p>
            <p id="next-prayer-countdown" class="mt-2 font-mono text-4xl font-bold text-white tabular-nums md:text-5xl">--:--:--</p>
            <p class="mt-1 text-[11px] font-semibold uppercase tracking-widest text-white/70">Hours : Minutes : Seconds</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Times grid — bigger cells, icons, staggered reveal -->
    <div class="reveal-stagger grid grid-cols-2 divide-x divide-y divide-gray-100 bg-white md:grid-cols-3 lg:grid-cols-6 lg:divide-y-0">
      {prayerTimes.map((t) => (
        <div class="prayer-cell group relative px-4 py-8 text-center transition-colors duration-300 hover:bg-green-50/70" data-adhan={t.adhan24} data-name={t.name}>
          <div class="prayer-highlight-bar absolute top-0 left-0 right-0 hidden h-1.5 bg-secondary"></div>
          <svg class="mx-auto mb-3 h-6 w-6 text-gold transition-transform duration-300 group-hover:scale-125" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={t.icon}/></svg>
          <p class="mb-3 text-sm font-bold uppercase tracking-widest text-gray-500">{t.name}</p>
          <p class="mb-2 text-3xl font-bold text-primary">{t.azan}</p>
          <p class="text-sm text-gray-500">Iqamah: {t.iqamah}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════
     ABOUT (white bg) — real content
════════════════════════════════════════════ -->
<section class="overflow-hidden bg-white py-24">
  <div class="mx-auto max-w-[1400px] px-6 md:px-16">
    <div class="grid items-center gap-16 md:grid-cols-2">
      <div class="group reveal relative order-2 md:order-1 p-8">
        <!-- Animated corner decorations -->
        <!-- Top-left corner bracket -->
        <div class="absolute top-0 left-0 h-16 w-16 border-t-4 border-l-4 rounded-tl-2xl transition-all duration-700 group-hover:h-24 group-hover:w-24" style="border-color: #C27121;"></div>
        <!-- Top-right corner dot cluster -->
        <div class="absolute top-2 right-2 flex gap-1.5" style="animation: float 4s ease-in-out infinite;">
          <span class="h-2.5 w-2.5 rounded-full bg-gold opacity-70"></span>
          <span class="h-2.5 w-2.5 rounded-full opacity-50" style="background:#0A2B1D;"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-gold opacity-30"></span>
        </div>
        <!-- Bottom-right corner bracket -->
        <div class="absolute bottom-0 right-0 h-16 w-16 border-b-4 border-r-4 rounded-br-2xl transition-all duration-700 group-hover:h-24 group-hover:w-24" style="border-color: #0A2B1D;"></div>
        <!-- Bottom-left floating badge -->
        <div class="absolute -bottom-4 -left-4 z-20 flex items-center gap-2 rounded-xl bg-primary px-4 py-2.5 text-white shadow-xl" style="animation: float 5s ease-in-out 1s infinite;">
          <span class="text-xl">🕌</span>
          <div>
            <p class="text-xs font-bold text-gold uppercase tracking-wider">Since 2004</p>
            <p class="text-xs text-white/70">Serving Loudoun County</p>
          </div>
        </div>
        <!-- Subtle rotating ring behind image -->
        <div class="absolute inset-6 rounded-2xl border border-gold/20" style="animation: float 8s ease-in-out 0.5s infinite;"></div>

        <img
          src="/About_real_image.png"
          alt="Loudoun Islamic Center community"
          loading="lazy"
          decoding="async"
          class="relative z-10 h-[420px] w-full rounded-2xl object-cover shadow-2xl transition-all duration-500 group-hover:shadow-primary/20 md:h-[540px]"
          style="box-shadow: 0 25px 60px rgba(10,43,29,0.2);"
        />
      </div>
      <div class="reveal order-1 md:order-2">
        <span class="mb-5 inline-block rounded-full border border-green-300 bg-green-100 px-3 py-1 text-xs font-bold uppercase tracking-widest text-primary">About Us</span>
        <h2 class="text-display-md font-display mb-8 leading-tight text-primary">About <span class="text-secondary">Loudoun Islamic Center</span></h2>
        <div class="space-y-5 text-lg leading-relaxed text-gray-500">
          <p>Loudoun Islamic Center is a diverse, non-sectarian, multi-ethnic, broad-minded community, with non-discriminatory policies and practices that encourage equal participation and involvement of men and women who are members of LIC and endorse its rules, regulations, and procedures, by virtue of their membership.</p>
        </div>
        <a href="/about" class="group mt-8 inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-all hover:scale-105 hover:bg-secondary">
          Read More
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════
     SERVICES — compact overview (full page lives at /services)
════════════════════════════════════════════ -->
<section class="border-t border-gray-100 bg-white py-20">
  <div class="mx-auto max-w-[1400px] px-6 md:px-16">
    <div class="reveal mb-12 flex flex-col justify-between gap-4 md:flex-row md:items-end">
