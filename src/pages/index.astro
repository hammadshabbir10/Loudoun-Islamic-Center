<!-- ════════════════════════════════════════════
     CLIENT SCRIPTS — Prayer Timer + FAQ Accordion + Scroll Reveal
════════════════════════════════════════════ -->
<script>
// ── Eastern Time clock & prayer countdown ─────────────────────────
const PRAYERS_ET = [
  { name: "Fajr",    h: 5,  m: 45 },
  { name: "Dhuhr",   h: 13, m: 15 },
  { name: "Asr",     h: 16, m: 30 },
  { name: "Maghrib", h: 18, m: 12 },
  { name: "Isha",    h: 19, m: 45 },
];

function getNowET() {
  return new Date(new Date().toLocaleString("en-US", { timeZone: "America/New_York" }));
}

function pad(n: number) { return String(n).padStart(2, "0"); }

function tick() {
  const now = getNowET();
  const h = now.getHours(), m = now.getMinutes(), s = now.getSeconds();

  // Clock display — AM/PM lives in its own smaller element so it never wraps
  const ampm = h >= 12 ? "PM" : "AM";
  const h12 = h % 12 || 12;
  const clockEl = document.getElementById("et-clock");
  const ampmEl = document.getElementById("et-ampm");
  if (clockEl) clockEl.textContent = `${h12}:${pad(m)}:${pad(s)}`;
  if (ampmEl) ampmEl.textContent = ampm;

  // Date display
  const dateEl = document.getElementById("et-date");
  if (dateEl) dateEl.textContent = now.toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric", year: "numeric" });

  // Next prayer countdown
  const totalMins = h * 60 + m;
  let nextPrayer = PRAYERS_ET.find(p => p.h * 60 + p.m > totalMins) || PRAYERS_ET[0];
  let nextMins = nextPrayer.h * 60 + nextPrayer.m;
  if (nextMins <= totalMins) nextMins += 24 * 60; // tomorrow Fajr
  const diffSec = (nextMins - totalMins) * 60 - s;
  const rh = Math.floor(diffSec / 3600);
  const rm = Math.floor((diffSec % 3600) / 60);
  const rs = diffSec % 60;

  // On Fridays the Dhuhr slot is Jumu'ah
  const isFriday = now.getDay() === 5;
  const displayName = isFriday && nextPrayer.name === "Dhuhr" ? "Jumu'ah" : nextPrayer.name;

  const nameEl = document.getElementById("next-prayer-name");
  const countEl = document.getElementById("next-prayer-countdown");
  if (nameEl) nameEl.textContent = displayName;
  if (countEl) countEl.textContent = `${pad(rh)}:${pad(rm)}:${pad(rs)}`;

  // Highlight the next upcoming prayer's cell.
  // Dhuhr and Jumu'ah share the same adhan time — highlight Jumu'ah only on
  // Fridays, and Dhuhr only on the other days.
  const nextMinOfDay = nextPrayer.h * 60 + nextPrayer.m;
  document.querySelectorAll<HTMLElement>(".prayer-cell").forEach(cell => {
    const adhan = cell.getAttribute("data-adhan");
    const name = cell.getAttribute("data-name");
    const bar = cell.querySelector(".prayer-highlight-bar");
    if (!adhan) return;
    const [ah, am] = adhan.split(":").map(Number);
    let isNext = ah * 60 + am === nextMinOfDay;
    if (name === "Jumu'ah") isNext = isNext && isFriday;
    else if (name === "Dhuhr") isNext = isNext && !isFriday;
    cell.style.background = isNext ? "#f0fdf4" : "";
    if (bar) bar.classList.toggle("hidden", !isNext);
  });
}

setInterval(tick, 1000);
tick();

// ── FAQ pure-JS accordion ─────────────────────────────────────────
document.querySelectorAll(".faq-item").forEach(item => {
  item.addEventListener("click", () => {
    const answer = item.querySelector(".faq-answer");
    const icon = item.querySelector<HTMLElement>(".faq-icon svg");
    const iconWrap = item.querySelector<HTMLElement>(".faq-icon");
    const button = item.querySelector("button");
    if (!answer) return;
    const isOpen = !answer.classList.contains("hidden");
    // Close all
    document.querySelectorAll(".faq-answer").forEach(a => a.classList.add("hidden"));
    document.querySelectorAll<HTMLElement>(".faq-icon svg").forEach(i => { i.style.transform = "rotate(0deg)"; i.style.color = ""; });
    document.querySelectorAll<HTMLElement>(".faq-icon").forEach(i => (i.style.background = ""));
    document.querySelectorAll(".faq-item button").forEach(b => b.setAttribute("aria-expanded", "false"));
    // Open clicked
    if (!isOpen) {
      answer.classList.remove("hidden");
      if (icon) { icon.style.transform = "rotate(180deg)"; icon.style.color = "white"; }
      if (iconWrap) iconWrap.style.background = "#0A2B1D";
      if (button) button.setAttribute("aria-expanded", "true");
    }
  });
});

// ── Scroll reveal (respects prefers-reduced-motion) ───────────────
if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
  document.documentElement.classList.add("js-reveal");
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 },
  );
  document.querySelectorAll(".reveal, .reveal-stagger").forEach((el) => io.observe(el));
}
</script>
