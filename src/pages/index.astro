---
import BaseLayout from "@/layouts/BaseLayout.astro";

const prayerTimes = [
  { name: "Fajr",    azan: "5:45 AM",  iqamah: "6:00",          adhan24: "05:45", icon: "M12 3v3m6.4.6l-2.1 2.1M6.6 6.6l2.1 2.1M4 20h16M7 16a5 5 0 0110 0" },
  { name: "Dhuhr",   azan: "1:15 PM",  iqamah: "1:30",          adhan24: "13:15", icon: "M12 2v2m0 16v2m10-10h-2M4 12H2m15.07-7.07l-1.41 1.41M6.34 17.66l-1.41 1.41m0-12.14l1.41 1.41m11.32 11.32l1.41 1.41M12 8a4 4 0 100 8 4 4 0 000-8z" },
  { name: "Asr",     azan: "4:30 PM",  iqamah: "4:45",          adhan24: "16:30", icon: "M4 20h16M6 16a6 6 0 1112 0M12 4v2m8.49 3.51l-1.41 1.41M4.92 10.92L3.51 9.51" },
  { name: "Maghrib", azan: "6:12 PM",  iqamah: "6:20",          adhan24: "18:12", icon: "M4 20h16M7 16a5 5 0 0110 0M12 3v6m0 0l3-3m-3 3L9 6" },
  { name: "Isha",    azan: "7:45 PM",  iqamah: "8:00",          adhan24: "19:45", icon: "M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" },
  { name: "Jumu'ah", azan: "1:15 PM",  iqamah: "2:15 PM (2nd)", adhan24: "13:15", icon: "M12 3l1.9 5.8h6.1l-4.95 3.6 1.9 5.8L12 14.6l-4.95 3.6 1.9-5.8L4 8.8h6.1L12 3z" },
];

const events = [
  {
    title: "Friday Khutbah",
    time: "Fridays @ 1:15 PM",
    category: "Weekly",
    image: "/friday-khutbah.png",
    description: "Join us for our weekly congregational prayer and an inspirational message from our Imam.",
  },
  {
    title: "Youth Quran Class",
    time: "Sundays @ 10:00 AM",
    category: "Education",
    image: "/kids-class.png",
    description: "Nurturing the love for the Quran in our children through interactive learning and tajweed practice.",
  },
  {
    title: "Community Iftar",
    time: "Monthly Social",
    category: "Special",
    image: "/community-iftar.png",
    description: "Bringing families together to share a meal, strengthen bonds, and celebrate our community.",
  },
];
---

<BaseLayout title="Loudoun Islamic Center - Home">

