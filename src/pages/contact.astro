---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/ContactForm.tsx";
---

<BaseLayout
  title="Contact"
  description="Get in touch — send us a message and we'll get back to you shortly."
>
  <section class="mx-auto max-w-xl px-4 py-16 sm:px-6">
    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Contact us</h1>
      <p class="text-muted-foreground mt-3 text-lg">
        Have a question or want to work together? Send us a message and we'll be
        in touch soon.
      </p>
    </div>
    <ContactForm client:load />
  </section>
</BaseLayout>
