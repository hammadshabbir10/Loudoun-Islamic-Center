{
  "name": "zikra-astro-starter",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Zikra Astro Starter — the reusable foundation every Zikra site is forked from. Astro 5 + Cloudflare Workers + Tailwind v4 + shadcn/ui.",
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/write-assetsignore.mjs",
    "preview": "pnpm build && wrangler dev",
    "sync": "astro sync",
    "check": "astro check",
    "typecheck": "astro sync && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types ./worker-configuration.d.ts --env-interface CloudflareEnv --include-runtime false",
    "cf-typegen:check": "wrangler types ./worker-configuration.d.ts --env-interface CloudflareEnv --include-runtime false --check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@hookform/resolvers": "^5.4.0",
    "@nanostores/react": "^1.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^5.18.2",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "^1.1.0",
    "astro-seo-schema": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "nanostores": "^1.4.0",
    "radix-ui": "^1.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.80.0",
    "schema-dts": "^2.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260630.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.7.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.6",
    "wrangler": "^4.42.0"
  }
}
