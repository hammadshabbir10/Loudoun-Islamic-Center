{
  "name": "loudoun-islamic-center",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "description": "Official website for the Loudoun Islamic Center (LIC) built with Astro, Tailwind CSS, and Cloudflare.",
  "engines": {
    "node": ">=22.15.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/write-assetsignore.mjs",
    "preview": "pnpm build && wrangler dev",
    "sync": "astro sync",
    "check": "astro check",
    "typecheck": "astro sync && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "pnpm audit --audit-level high",
    "verify:build": "node scripts/verify-build.mjs",
    "cf-typegen": "wrangler types ./worker-configuration.d.ts --include-runtime false",
    "cf-typegen:check": "wrangler types ./worker-configuration.d.ts --include-runtime false --check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@hookform/resolvers": "^5.4.0",
    "@nanostores/react": "^1.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "^1.1.0",
    "astro-seo-schema": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "nanostores": "^1.4.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "schema-dts": "^1.1.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^5.20260723.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^3.2.7",
    "wrangler": "^4.113.0"
  }
}